# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/meddef_db

# Public base URL (used in metadata / absolute redirects)
NEXT_PUBLIC_URL=http://localhost:3000

# Paths to ONNX models and dataset samples served from /public
NEXT_PUBLIC_MODELS_DIR=/models/onnx
NEXT_PUBLIC_DATASETS_DIR=/datasets

# Absolute path to ONNX model files on the server (server-side only).
# On the VPS this is /home/hetawk/models/2026 — set this in lpad's environment
# manager so it persists across redeployments.
# Omit for local dev (falls back to public/models/onnx automatically).
MODEL_DIR=/home/hetawk/models/2026
