# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored (it has no real secrets)

# ── Dependencies ──────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Prisma generated client (regenerated via `npm run db:generate`) ───────────
/src/generated/

# ── Certificates & keys ───────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Testing / coverage ────────────────────────────────────────────────────────
/coverage

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── Large binary / dataset files (store in cloud storage, not git) ────────────
/public/models/
/public/datasets/
